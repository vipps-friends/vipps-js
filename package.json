{
  "author": "Robert Sasak",
  "description": "A modern JavaScript library for Vipps MobilePay APIs",
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@types/node": "^22.13.0",
    "semantic-release": "^24.2.3",
    "typescript": "^5.7.3"
  },
  "files": [
    "src",
    "types"
  ],
  "keywords": [
    "vipps",
    "mobilepay",
    "payments",
    "javascript",
    "node.js",
    "deno",
    "bun"
  ],
  "license": "MIT",
  "main": "src/index.js",
  "name": "@vipps-friends/vipps-js",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "release": {
    "branches": [
      "main"
    ]
  },
  "repository": {
    "url": "https://github.com/vipps-friends/vipps-js"
  },
  "scripts": {
    "check": "biome check --write .",
    "download-spec": "./scripts/download-openapi.sh",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "test": "node --env-file=.env.local --test src/**/*.test.js",
    "typegen": "tsc"
  },
  "type": "module",
  "types": "types/index.d.ts",
  "version": "1.0.0"
}
